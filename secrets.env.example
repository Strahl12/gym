# Copy to `secrets.env` and fill in your secrets. The real secrets.env is gitignored.

ANTHROPIC_API_KEY=
HEVY_API_KEY=

WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Optional — only needed if bootstrapping the refresh token by hand
# instead of via `python run.py --withings-auth`. Normally leave blank.
WITHINGS_REFRESH_TOKEN=
WITHINGS_ACCESS_TOKEN=

# Optional — port for the local OAuth callback listener (default: 8765)
# WITHINGS_OAUTH_PORT=8765
