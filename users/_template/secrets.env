# Per-user secrets. Copy to users/<your-name>/secrets.env and fill in.
# Shared ANTHROPIC_API_KEY lives in the root secrets.env (or shell env).

# Hevy API key — get at https://hevy.com/settings?developer
HEVY_API_KEY=

# Withings (optional — bodyweight tracking)
# The app registration (client ID/secret) is shared and lives in the ROOT
# secrets.env — leave these blank unless this user needs a different app.
# To connect this user's Withings account, run:
#   python run.py --user <name> --withings-auth
# Refresh token is cached under users/<name>/withings_token.json.
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REFRESH_TOKEN=

# Optional — port for the local OAuth callback listener (default: 8765)
# WITHINGS_OAUTH_PORT=8765

# Web chat — secret access token for chat_server.py. The add-user wizard
# generates this; the user's chat URL is  https://<funnel-host>:8443/u/<token>
CHAT_TOKEN=
